# Apache configuration for PFL Project — https://pflproject.com
# Performance, security, and SEO optimizations for cPanel deployment

# ─── URL Rewriting (SPA Fallback) ─────────────────────────────────────────────────
RewriteEngine On
RewriteBase /

# Remove trailing slashes (SEO: consistent URLs)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [L,R=301]

# SPA fallback — serve index.html for all non-file routes
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# ─── Security Headers ─────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # HSTS (HTTP Strict Transport Security) — enable for production with SSL
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS

  # Content Security Policy (adjust as needed)
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # Cache-Control for static assets
  <FilesMatch "\.(ico|pdf|jpg|jpeg|png|gif|svg|webp|js|css|woff|woff2|ttf|eot)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  <FilesMatch "\.(html|xml|txt|json)$">
    Header set Cache-Control "max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ─── Compression ──────────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml font/woff2
</IfModule>

# ─── MIME Types ───────────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType font/woff .woff
</IfModule>

# ─── Block Access to Sensitive Files ──────────────────────────────────────────────
<FilesMatch "\.(env|git|htaccess|htpasswd|ini|log|sh|sql|md|lock)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ─── Directory Browsing ───────────────────────────────────────────────────────────
Options -Indexes